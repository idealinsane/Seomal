generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/seomal.db"
}

model Graph {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  nodes     Node[]
  edges     Edge[]
}

model Node {
  id      Int    @id @default(autoincrement())
  key     String
  label   String
  url     String @default("")
  content String @default("")
  graphId Int
  graph   Graph  @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@unique([graphId, key])
}

model Edge {
  id      Int    @id @default(autoincrement())
  source  String
  target  String
  graphId Int
  graph   Graph  @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@unique([graphId, source, target])
}
